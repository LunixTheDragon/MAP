<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<BorderPane fx:id="rootPane" stylesheets="@style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="graphics.ChatController">
    <padding>
        <Insets top="15" right="25" bottom="25" left="25"/>
    </padding>

    <top>
        <HBox alignment="CENTER" styleClass="glass-panel" style="-fx-padding: 10 20 10 15;">
            <BorderPane.margin>
                <Insets bottom="20.0" />
            </BorderPane.margin>

            <HBox alignment="CENTER_LEFT" spacing="12" styleClass="profile-area" onMouseClicked="#handleProfileSettings">
                <Circle fx:id="profileImageCircle" radius="22" fill="#007AFF" />
                <VBox alignment="CENTER_LEFT">
                    <Label styleClass="dynamic-text" style="-fx-font-weight: 800; -fx-font-size: 13px; -fx-text-fill: #86868b;" text="MŮJ PROFIL" />
                    <Label fx:id="currentUserLabel" style="-fx-font-weight: bold; -fx-text-fill: #007AFF; -fx-font-size: 18px;" text="User" />
                </VBox>
            </HBox>

            <javafx.scene.layout.Region HBox.hgrow="ALWAYS" />

            <HBox fx:id="receiverProfileBox" alignment="CENTER" spacing="12" visible="false">
                <Circle fx:id="receiverImageCircle" radius="22" fill="#e5e5ea" />
                <VBox alignment="CENTER_LEFT">
                    <Label styleClass="dynamic-text" style="-fx-font-weight: 800; -fx-font-size: 13px; -fx-text-fill: #86868b;" text="CHATOVÁNÍ S" />
                    <Label fx:id="receiverUserLabel" styleClass="dynamic-text" style="-fx-font-weight: bold; -fx-font-size: 18px;" text="Příjemce" />
                </VBox>
            </HBox>

            <javafx.scene.layout.Region HBox.hgrow="ALWAYS" />
            <HBox alignment="CENTER_RIGHT" spacing="5">
                <Button styleClass="icon-btn" text="➕ Nový chat" onAction="#handleNewChat"/>
                <Button fx:id="themeBtn" styleClass="icon-btn" text="🌙" onAction="#toggleDarkMode"/>
                <Button styleClass="icon-btn" text="⚙Nastavení" onAction="#handleProfileSettings"/>
                <Button styleClass="icon-btn, logout-btn" text="🚪 Odhlásit" onAction="#handleSignOut"/>
            </HBox>
        </HBox>
    </top>

    <center>
        <HBox spacing="15">
            <BorderPane.margin>
                <Insets bottom="20.0" />
            </BorderPane.margin>

            <VBox styleClass="glass-panel" prefWidth="250" minWidth="250" style="-fx-padding: 15;">
                <Label styleClass="header-label" style="-fx-font-size: 16px; -fx-padding: 0 0 10 0;" text="Moje chaty" />
                <javafx.scene.control.ScrollPane fitToWidth="true" styleClass="modern-scroll-pane" VBox.vgrow="ALWAYS" hbarPolicy="NEVER">
                    <content>
                        <VBox fx:id="sidebarList" spacing="5" />
                    </content>
                </javafx.scene.control.ScrollPane>
            </VBox>

            <VBox styleClass="glass-panel" style="-fx-padding: 10;" HBox.hgrow="ALWAYS">
                <javafx.scene.control.ScrollPane fx:id="scrollPane" fitToWidth="true" styleClass="modern-scroll-pane" VBox.vgrow="ALWAYS" hbarPolicy="NEVER">
                    <content>
                        <VBox fx:id="chatContainer" spacing="12" style="-fx-padding: 10;" />
                    </content>
                </javafx.scene.control.ScrollPane>
            </VBox>

        </HBox>
    </center>

    <bottom>
        <VBox spacing="10" styleClass="glass-panel" style="-fx-padding: 18;">
            <HBox spacing="10" alignment="CENTER_LEFT">
                <TextField fx:id="targetUserField" promptText="Příjemce..." prefWidth="140" styleClass="input-field" />
                <Button onAction="#handleLoadChat" styleClass="primary-btn" text="Otevřít chat" style="-fx-padding: 10 20; -fx-background-color: #34c759;"/>
                <Button onAction="#handleManualRefresh" styleClass="primary-btn" text="🔄 Obnovit zprávy" style="-fx-padding: 10 20; -fx-background-color: #8e8e93;"/>
            </HBox>

            <HBox spacing="15" alignment="CENTER">
                <TextField fx:id="messageField" promptText="Napiš zprávu..." HBox.hgrow="ALWAYS" styleClass="input-field" onAction="#handleSendMessage" disable="true"/>
                <Button fx:id="sendBtn" onAction="#handleSendMessage" styleClass="primary-btn" text="Odeslat" style="-fx-padding: 12 25;" disable="true"/>
            </HBox>
        </VBox>
    </bottom>

</BorderPane>